{
	"name": "Seller Application",
	"doctype": "DocType",
	"module": "Tradehub Core",
	"naming_rule": "Expression (old style)",
	"autoname": "SA-.#####",
	"engine": "InnoDB",
	"track_changes": 1,
	"sort_field": "modified",
	"sort_order": "DESC",
	"title_field": "business_name",
	"fields": [
		{
			"fieldname": "applicant_user",
			"fieldtype": "Link",
			"label": "Applicant User",
			"options": "User",
			"reqd": 1,
			"search_index": 1,
			"in_list_view": 1,
			"set_only_once": 1
		},
		{
			"fieldname": "member_id",
			"fieldtype": "Data",
			"label": "Member ID",
			"read_only": 1,
			"description": "System-generated unique membership number (TH-XXXXXXXX)"
		},
		{
			"fieldname": "cb_status",
			"fieldtype": "Column Break"
		},
		{
			"fieldname": "status",
			"fieldtype": "Select",
			"label": "Status",
			"options": "Draft\nSubmitted\nUnder Review\nApproved\nRejected",
			"default": "Draft",
			"in_list_view": 1,
			"in_standard_filter": 1,
			"reqd": 1
		},
		{
			"fieldname": "sb_business",
			"fieldtype": "Section Break",
			"label": "Business Information"
		},
		{
			"fieldname": "business_name",
			"fieldtype": "Data",
			"label": "Business Name",
			"in_list_view": 1
		},
		{
			"fieldname": "seller_type",
			"fieldtype": "Select",
			"label": "Seller Type",
			"options": "\nIndividual\nBusiness\nEnterprise",
			"in_standard_filter": 1
		},
		{
			"fieldname": "cb_contact",
			"fieldtype": "Column Break"
		},
		{
			"fieldname": "contact_email",
			"fieldtype": "Data",
			"label": "Contact Email",
			"options": "Email"
		},
		{
			"fieldname": "contact_phone",
			"fieldtype": "Data",
			"label": "Contact Phone",
			"options": "Phone"
		},
		{
			"fieldname": "sb_tax",
			"fieldtype": "Section Break",
			"label": "Tax Information"
		},
		{
			"fieldname": "tax_id_type",
			"fieldtype": "Select",
			"label": "Tax ID Type",
			"options": "\nTCKN\nVKN"
		},
		{
			"fieldname": "tax_id",
			"fieldtype": "Data",
			"label": "Tax ID"
		},
		{
			"fieldname": "tax_office",
			"fieldtype": "Data",
			"label": "Tax Office"
		},
		{
			"fieldname": "sb_address",
			"fieldtype": "Section Break",
			"label": "Address"
		},
		{
			"fieldname": "address_line_1",
			"fieldtype": "Data",
			"label": "Address Line 1"
		},
		{
			"fieldname": "city",
			"fieldtype": "Data",
			"label": "City"
		},
		{
			"fieldname": "cb_address",
			"fieldtype": "Column Break"
		},
		{
			"fieldname": "country",
			"fieldtype": "Link",
			"label": "Country",
			"options": "Country"
		},
		{
			"fieldname": "sb_bank",
			"fieldtype": "Section Break",
			"label": "Bank Information"
		},
		{
			"fieldname": "bank_name",
			"fieldtype": "Data",
			"label": "Bank Name"
		},
		{
			"fieldname": "iban",
			"fieldtype": "Data",
			"label": "IBAN"
		},
		{
			"fieldname": "cb_bank",
			"fieldtype": "Column Break"
		},
		{
			"fieldname": "account_holder_name",
			"fieldtype": "Data",
			"label": "Account Holder Name"
		},
		{
			"fieldname": "sb_identity",
			"fieldtype": "Section Break",
			"label": "Identity Document"
		},
		{
			"fieldname": "identity_document_type",
			"fieldtype": "Select",
			"label": "Identity Document Type",
			"options": "\nNational ID Card\nPassport\nDriver License"
		},
		{
			"fieldname": "identity_document_number",
			"fieldtype": "Data",
			"label": "Identity Document Number"
		},
		{
			"fieldname": "identity_document_expiry",
			"fieldtype": "Date",
			"label": "Identity Document Expiry"
		},
		{
			"fieldname": "cb_identity",
			"fieldtype": "Column Break"
		},
		{
			"fieldname": "identity_document",
			"fieldtype": "Attach",
			"label": "Identity Document"
		},
		{
			"fieldname": "sb_terms",
			"fieldtype": "Section Break",
			"label": "Agreements",
			"collapsible": 1
		},
		{
			"fieldname": "terms_accepted",
			"fieldtype": "Check",
			"label": "Terms of Service Accepted",
			"default": "0"
		},
		{
			"fieldname": "privacy_accepted",
			"fieldtype": "Check",
			"label": "Privacy Policy Accepted",
			"default": "0"
		},
		{
			"fieldname": "kvkk_accepted",
			"fieldtype": "Check",
			"label": "KVKK Accepted",
			"default": "0"
		},
		{
			"fieldname": "cb_terms",
			"fieldtype": "Column Break"
		},
		{
			"fieldname": "commission_accepted",
			"fieldtype": "Check",
			"label": "Commission Agreement Accepted",
			"default": "0"
		},
		{
			"fieldname": "return_policy_accepted",
			"fieldtype": "Check",
			"label": "Return Policy Accepted",
			"default": "0"
		},
		{
			"fieldname": "sb_review",
			"fieldtype": "Section Break",
			"label": "Review",
			"collapsible": 1,
			"depends_on": "eval:doc.status !== 'Draft'"
		},
		{
			"fieldname": "reviewed_by",
			"fieldtype": "Link",
			"label": "Reviewed By",
			"options": "User",
			"read_only": 1
		},
		{
			"fieldname": "reviewed_on",
			"fieldtype": "Datetime",
			"label": "Reviewed On",
			"read_only": 1
		},
		{
			"fieldname": "cb_review",
			"fieldtype": "Column Break"
		},
		{
			"fieldname": "review_notes",
			"fieldtype": "Small Text",
			"label": "Review Notes"
		}
	],
	"permissions": [
		{
			"role": "System Manager",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 1,
			"email": 1,
			"print": 1,
			"report": 1,
			"share": 1,
			"export": 1,
			"import": 1
		},
		{
			"role": "Marketplace Admin",
			"read": 1,
			"write": 1,
			"create": 1,
			"report": 1,
			"export": 1
		},
		{
			"role": "Buyer",
			"read": 1,
			"create": 1,
			"if_owner": 1
		}
	],
	"actions": [],
	"links": [],
	"states": []
}
