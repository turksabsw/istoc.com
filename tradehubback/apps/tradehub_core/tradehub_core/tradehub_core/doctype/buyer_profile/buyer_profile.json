{
	"name": "Buyer Profile",
	"doctype": "DocType",
	"module": "Tradehub Core",
	"naming_rule": "By fieldname",
	"autoname": "field:user",
	"engine": "InnoDB",
	"track_changes": 1,
	"sort_field": "modified",
	"sort_order": "DESC",
	"fields": [
		{
			"fieldname": "user",
			"fieldtype": "Link",
			"label": "User",
			"options": "User",
			"reqd": 1,
			"unique": 1,
			"set_only_once": 1,
			"search_index": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "member_id",
			"fieldtype": "Data",
			"label": "Member ID",
			"read_only": 1,
			"in_list_view": 1,
			"bold": 1,
			"description": "System-generated unique membership number (TH-XXXXXXXX)"
		},
		{
			"fieldname": "cb_main",
			"fieldtype": "Column Break"
		},
		{
			"fieldname": "buyer_name",
			"fieldtype": "Data",
			"label": "Buyer Name",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "sb_details",
			"fieldtype": "Section Break",
			"label": "Details"
		},
		{
			"fieldname": "country",
			"fieldtype": "Link",
			"label": "Country",
			"options": "Country"
		},
		{
			"fieldname": "phone",
			"fieldtype": "Data",
			"label": "Phone",
			"options": "Phone"
		},
		{
			"fieldname": "cb_status",
			"fieldtype": "Column Break"
		},
		{
			"fieldname": "status",
			"fieldtype": "Select",
			"label": "Status",
			"options": "Active\nSuspended\nDeactivated",
			"default": "Active",
			"in_list_view": 1,
			"in_standard_filter": 1
		},
		{
			"fieldname": "email_verified",
			"fieldtype": "Check",
			"label": "Email Verified",
			"default": "0",
			"read_only": 1
		}
	],
	"permissions": [
		{
			"role": "System Manager",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 1,
			"email": 1,
			"print": 1,
			"report": 1,
			"share": 1,
			"export": 1,
			"import": 1
		},
		{
			"role": "Marketplace Admin",
			"read": 1,
			"write": 1,
			"create": 1,
			"report": 1,
			"export": 1
		},
		{
			"role": "Buyer",
			"read": 1,
			"if_owner": 1
		}
	],
	"actions": [],
	"links": [],
	"states": []
}
