{
 "name": "Seller Profile",
 "doctype": "DocType",
 "module": "TradeHub Core",
 "naming_rule": "By fieldname",
 "autoname": "field:user",
 "engine": "InnoDB",
 "track_changes": 1,
 "sort_field": "modified",
 "sort_order": "DESC",
 "title_field": "seller_name",
 "fields": [
  {
   "fieldname": "user",
   "fieldtype": "Link",
   "label": "User",
   "options": "User",
   "reqd": 1,
   "unique": 1,
   "set_only_once": 1,
   "search_index": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "member_id",
   "fieldtype": "Data",
   "label": "Member ID",
   "read_only": 1,
   "in_list_view": 1,
   "bold": 1,
   "description": "System-generated unique membership number (TH-XXXXXXXX)"
  },
  {
   "fieldname": "cb_main",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "seller_name",
   "fieldtype": "Data",
   "label": "Seller Name",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "status",
   "fieldtype": "Select",
   "label": "Status",
   "options": "Active\nSuspended\nDeactivated",
   "default": "Active",
   "in_list_view": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "sb_details",
   "fieldtype": "Section Break",
   "label": "Details"
  },
  {
   "fieldname": "seller_type",
   "fieldtype": "Select",
   "label": "Seller Type",
   "options": "\nIndividual\nBusiness\nEnterprise"
  },
  {
   "fieldname": "application",
   "fieldtype": "Link",
   "label": "Application",
   "options": "Seller Application",
   "read_only": 1
  },
  {
   "fieldname": "cb_details",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "business_name",
   "fieldtype": "Data",
   "label": "Business Name"
  },
  {
   "fieldname": "tax_id",
   "fieldtype": "Data",
   "label": "Tax ID"
  },
  {
   "fieldname": "contact_phone",
   "fieldtype": "Data",
   "label": "Contact Phone",
   "options": "Phone"
  },
  {
   "fieldname": "country",
   "fieldtype": "Link",
   "label": "Country",
   "options": "Country"
  }
 ],
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "email": 1,
   "print": 1,
   "report": 1,
   "share": 1,
   "export": 1,
   "import": 1
  },
  {
   "role": "Marketplace Admin",
   "read": 1,
   "write": 1,
   "create": 1,
   "report": 1,
   "export": 1
  },
  {
   "role": "Seller",
   "read": 1,
   "if_owner": 1
  }
 ],
 "actions": [],
 "links": [],
 "states": []
}