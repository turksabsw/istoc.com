# ============================================================
# Port Yapılandırması — Tüm portları buradan yönetin
# ============================================================

# Frontend (nginx)
FRONTEND_PORT=5500

# Frappe Backend (Gunicorn) — yerel 8000 dolu, Docker 8001 kullanır
BACKEND_PORT=8001

# Frappe WebSocket / Socket.IO — yerel 9000 dolu, Docker 9001 kullanır
SOCKETIO_PORT=9001

# MariaDB — yerel 3306/3307 dolu, Docker 3308 kullanır
DB_PORT=3308

# Redis Cache — yerel 13000/13001 dolu, Docker 13002 kullanır
REDIS_CACHE_PORT=13002

# Redis Queue — yerel 11000/11001 dolu, Docker 11002 kullanır
REDIS_QUEUE_PORT=11002

# ============================================================
# Veritabanı Yapılandırması
# ============================================================
DB_ROOT_PASSWORD=changeme
DB_NAME=_a442feea467abfcc
DB_PASSWORD=rCN4UEwX6mG2wWui

# ============================================================
# Frappe Yapılandırması
# ============================================================
FRAPPE_SITE_NAME=tradehub.localhost

# Site URL — email linkleri (sifre sifirlama, email dogrulama) icin kullanilir
# Prod: https://istoc.com
HOST_NAME=http://localhost:5500

# ============================================================
# Frontend Build
# ============================================================
# Nginx üzerinden proxy yapıldığı için /api kullanılır
VITE_API_URL=/api

# ============================================================
# Mail (SMTP) Yapılandırması
# ============================================================
# Dev: Mailpit (varsayılan), Prod: gerçek SMTP sağlayıcısı
# Prod örneği:
#   MAIL_SERVER=smtp.yandex.com
#   MAIL_PORT=465
#   MAIL_USE_SSL=1
#   MAIL_USE_TLS=0
#   MAIL_LOGIN=noreply@istoc.com
#   MAIL_PASSWORD=uygulama-sifresi
#   MAIL_DEFAULT_SENDER=noreply@istoc.com
#   MAIL_DISABLE_AUTH=0
MAIL_SERVER=mailpit
MAIL_PORT=1025
MAIL_USE_SSL=0
MAIL_USE_TLS=0
MAIL_LOGIN=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@tradehub.localhost
MAIL_DISABLE_AUTH=1
